{
  "name": "sudiptpa/paypal-notifications",
  "description": "Framework-agnostic PayPal Notifications SDK for webhook signature verification and legacy Instant Payment Notification verification.",
  "type": "library",
  "license": "MIT",
  "keywords": ["paypal", "webhooks", "instant payment notification", "ipn", "notifications"],
  "authors": [
    {
      "name": "Sujip Thapa",
      "email": "sudiptpa@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.2 <=8.5",
    "ext-json": "*",
    "ext-curl": "*"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.12 || ^2.0",
    "phpunit/phpunit": "^10.5 || ^11.0"
  },
  "autoload": {
    "psr-4": {
      "Sujip\\PayPal\\Notifications\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Sujip\\PayPal\\Notifications\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "stan": "phpstan analyse --configuration=phpstan.neon.dist",
    "test": "phpunit",
    "test:coverage": "phpunit --coverage-text"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
